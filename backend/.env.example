APP_NAME=Instagram DM AI Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_DB=instagram_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/instagram_ai
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@postgres:5432/instagram_ai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
